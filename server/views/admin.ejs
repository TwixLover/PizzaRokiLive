<!DOCTYPE html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <title>Admin Panel</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin/admin.css" />
</head>

<body class="p-4">

<h2 class="mb-4">Admin Panel</h2>



<ul class="nav nav-tabs mb-4">
  <li class="nav-item">
    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#menu">
      Menü elemek
    </button>
  </li>

  <li class="nav-item">
    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#users">
      Felhasználók
    </button>
  </li>
</ul>

<div class="tab-content">
  <div class="tab-pane fade show active" id="menu">
    <div class="admin-search mb-4 w-25 ">
  <input 
    type="text"
    class="form-control js-admin-search"
    placeholder="Search menu item..."
  >
</div>
<div class="d-flex justify-content-end mb-3 gap-5 align-items-center">
  
  <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addItemModal">
    + Új menü elem
  </button>
</div>

    <% const types = [...new Set(menuItems.map(i => i.type))]; %>

    <% types.forEach(type => { %>
      <div class="menu-category">
        <h4><%= type %></h4>

        <div class="menu-grid">
          <% menuItems.filter(item => item.type === type).forEach(item => { %>

          <div class="menu-card" data-id="<%= item.id %>">

            <input class="form-control mb-2 js-name" value="<%= item.name %>" />
            <textarea class="form-control mb-2 js-description"><%= item.description %></textarea>
            <input class="form-control mb-2 js-price" value="<%= item.base_price %>" />
            <input class="form-control mb-2 js-image" value="<%= item.image_url %>" />

            <div class="d-flex gap-2">
              <button class="btn btn-primary w-100 js-save">Mentés</button>
              <button class="btn btn-danger w-100 js-delete">Törlés</button>
            </div>

          </div>

          <% }) %>
        </div>
      </div>
    <% }) %>

  </div>
  <div class="tab-pane fade" id="users">

  <div class="admin-search mb-4 w-25 ">
    <input
      type="text"
      class="form-control js-user-search"
      placeholder="Felhasználó keresése..."
    >
  </div>
  

  <div class="menu-grid">

    <% users.forEach(user => { %>

      <div class="menu-card user-card" data-id="<%= user.id %>">

  
        <input
          class="form-control mb-2 js-user-email"
          value="<%= user.email || '' %>"
          placeholder="Email"
        >

        <input
          class="form-control mb-2 js-user-first-name"
          value="<%= user.first_name || '' %>"
          placeholder="Keresztnév"
        >

        <input
          class="form-control mb-2 js-user-last-name"
          value="<%= user.last_name || '' %>"
          placeholder="Vezetéknév"
        >

        <input
          class="form-control mb-2 js-user-phone"
          value="<%= user.phone || '' %>"
          placeholder="Telefon"
        >

        <input
          class="form-control mb-2 js-user-street"
          value="<%= user.street || '' %>"
          placeholder="Utca"
        >

        <input
          class="form-control mb-2 js-user-house-number"
          value="<%= user.house_number || '' %>"
          placeholder="Házszám"
        >

        <input
          class="form-control mb-2 js-user-city"
          value="<%= user.city || '' %>"
          placeholder="Város"
        >

        <input
          class="form-control mb-2 js-user-postal-code"
          value="<%= user.postal_code || '' %>"
          placeholder="Irányítószám"
        >

        <select class="form-control mb-2 js-user-role">

          <option
            value="user"
            <%= user.role === "user" ? "selected" : "" %>>
            user
          </option>

          <option
            value="employee"
            <%= user.role === "employee" ? "selected" : "" %>>
            employee
          </option>

        </select>

        <div class="d-flex gap-2">

          <button
            class="btn btn-primary w-100 js-user-save">
            Mentés
          </button>

          <button
            class="btn btn-danger w-100 js-user-delete">
            Törlés
          </button>

        </div>

      </div>

    <% }) %>

  </div>

</div>
</div>

<!-- Modal -->
<div class="modal fade" id="addItemModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Új menü elem</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <input class="form-control mb-2 js-new-name" placeholder="Név" />
        <textarea class="form-control mb-2 js-new-description" placeholder="Leírás"></textarea>
        <input class="form-control mb-2 js-new-price" placeholder="Alapár" />
        <input class="form-control mb-2 js-new-image" placeholder="Kép URL" />
        <select class="form-control js-new-type">
          <% types.forEach(t => { %>
            <option value="<%= t %>"><%= t %></option>
          <% }) %>
        </select>
      </div>

      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Mégse</button>
        <button class="btn btn-success js-add-item">Hozzáadás</button>
      </div>

    </div>
  </div>
</div>


<script src="/js/update.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>